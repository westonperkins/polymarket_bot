# Get this from Supabase: Project Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Trading mode: "paper" (default) or "live"
TRADING_MODE=paper

# ── Live trading only (required when TRADING_MODE=live) ──────────────
# Your Polymarket wallet private key (DO NOT share this)
POLYMARKET_PRIVATE_KEY=
# Your funder address (the wallet address holding your USDC)
POLYMARKET_FUNDER_ADDRESS=
# Signature type: 0=EOA (MetaMask etc), 1=Email/Magic wallet, 2=Browser proxy
POLYMARKET_SIGNATURE_TYPE=0

# Risk limits (as percentages of starting balance)
LIVE_MAX_DAILY_LOSS_PCT=10
LIVE_MAX_POSITION_SIZE_PCT=5
LIVE_MIN_BALANCE_PCT=20
