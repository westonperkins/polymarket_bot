# Get this from Supabase: Project Settings → Database → Connection string (URI)
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Trading mode: "paper" (default) or "live"
TRADING_MODE=paper

# Binance region: "us" for US machines, "global" for European VPS (default: global)
BINANCE_REGION=global

# Entry timing: seconds before market close to analyze signals and place orders
# 30 = original, 60 = more liquidity but less signal data
ENTRY_SECONDS_BEFORE_CLOSE=30

# ── Trading Hours ──────────────────────────────────────────────────────
# Blackout window in PST — bot skips trading during these hours
TRADING_BLACKOUT_START_PST=22     # default: 22 (10 PM PST)
TRADING_BLACKOUT_END_PST=8        # default: 8 (8 AM PST)

# ── Risk per trade (fraction of current portfolio) ────────────────────
# These apply to both paper and live trading.
# With a small balance (<$50), increase these so orders are large enough
# to fill on Polymarket's order book (minimum ~$1-2 per order).
RISK_HIGH_CONFIDENCE=0.05         # default: 0.05 (5%)
RISK_MEDIUM_CONFIDENCE=0.025      # default: 0.025 (2.5%)

# ── Live trading only (required when TRADING_MODE=live) ──────────────
# Your Polymarket wallet private key (DO NOT share this)
POLYMARKET_PRIVATE_KEY=
# Your funder address (the wallet address holding your USDC)
POLYMARKET_FUNDER_ADDRESS=
# Signature type: 0=EOA (MetaMask etc), 1=Email/Magic wallet, 2=Browser proxy
POLYMARKET_SIGNATURE_TYPE=0

# Live starting balance is auto-detected from your wallet on first launch
# and saved to the database. No need to set it manually.

# Risk limits for live trading (as percentages of starting balance)
LIVE_MAX_DAILY_LOSS_PCT=10        # default: 10 — stop trading if down 10% today
LIVE_MIN_BALANCE_PCT=20           # default: 20 — stop trading if balance drops below 20%
LIVE_MAX_SLIPPAGE_PCT=10          # default: 10 — max % above quoted odds to pay per share
LIVE_MIN_FILL_PRICE=0.20          # default: 0.20 — reject fills below this price per share

# ── Builder API (for auto-claim via relayer) ────────────────────────
# Create at: polymarket.com/settings?tab=builder → Builder Keys → + Create New
# Secret and passphrase are only shown once — save them immediately
POLY_BUILDER_API_KEY=
POLY_BUILDER_SECRET=
POLY_BUILDER_PASSPHRASE=

# ── Notifications ────────────────────────────────────────────────────
# Discord webhook URL for trade notifications (wins, losses)
# Create at: Server Settings → Integrations → Webhooks
DISCORD_WEBHOOK_URL=

# ── FAK (Market) Orders ──────────────────────────────────────────────
FAK_ORDER_ENABLED=true                 # default: true — set to false to disable T-30 market orders

# ── Limit Orders ─────────────────────────────────────────────────────
LIMIT_ORDER_ENABLED=false              # default: false — set to true to use GTC limit orders
LIMIT_ENTRY_SECONDS_BEFORE_CLOSE=120   # default: 120 — when to place limit order
LIMIT_CANCEL_SECONDS_BEFORE_CLOSE=15   # default: 15 — when to cancel unfilled
LIMIT_EDGE_DISCOUNT_BPS=200            # default: 200 — bps below fair value to bid
LIMIT_MIN_SHARES=5                     # default: 5 — Polymarket enforced minimum
LIMIT_FORCE_MIN_SHARES=false           # default: false — override to min shares when balance is low
LIMIT_MIN_RR=1.0                       # default: 1.0 — minimum R:R to place limit order (ignored when ML gate uses dynamic R:R)
LIMIT_FILL_EXPIRY_SEC=10               # default: 10 — cancel unfilled orders after N seconds

# ── ML Gate ──────────────────────────────────────────────────────────
ML_GATE_ENABLED=false                  # default: false — set to true to enable
ML_CONFIDENCE_THRESHOLD=0.60           # default: 0.60 — minimum P(win) to take a trade
ML_MODEL_PATH=ml/output/gate_model.json

# ── Taker Mode (step 2 validation) ───────────────────────────────────
# When TAKER_MODE_ENABLED=true, the ML gate at T-30 routes to a marketable
# FAK at (mid + slippage cap) instead of placing a passive limit. Designed
# for live small-sample validation of the simulated taker counterfactual in
# ml/backtest.py:simulate_taker_holdout.
#
# Recommended step 2 procedure:
#   1. Set TAKER_MODE_ENABLED=true and ML_CONFIDENCE_THRESHOLD=0.55
#   2. Run for 48–72 hours, target 30–50 resolved taker trades
#   3. Compare live win rate / avg PnL against the holdout numbers
#      (~82% win rate, ~$0.62/trade per dollar invested)
#   4. If they line up, raise TAKER_MODE_SIZE_MULT to 1.0 and scale
#   5. The auto-halt monitor will fall back to the limit path if
#      win rate drops below TAKER_MODE_MIN_WIN_RATE or avg PnL drops
#      below TAKER_MODE_MIN_AVG_PNL over the last N trades.
TAKER_MODE_ENABLED=false               # default: false — master switch
TAKER_MODE_SIZE_MULT=0.5               # default: 0.5 — half normal size for validation
TAKER_MODE_MAX_SLIPPAGE_CENTS=3        # default: 3 — cap slippage above mid (cents/share)
TAKER_MODE_HALT_AFTER_N=30             # default: 30 — start checking auto-halt after N trades
TAKER_MODE_MIN_WIN_RATE=0.65           # default: 0.65 — halt if rolling win rate drops below this
TAKER_MODE_MIN_AVG_PNL=0.20            # default: 0.20 — halt if rolling avg PnL/trade drops below this
